# =====================================================
#  ISF 2026 — Environment Variables TEMPLATE
#  Copy this file, rename it to .env, then fill in
#  your real keys. NEVER commit .env to Git.
# =====================================================

# Paystack Keys
# Get from: dashboard.paystack.com → Settings → API Keys & Webhooks
PAYSTACK_SECRET_KEY=your_paystack_secret_key_here
PAYSTACK_PUBLIC_KEY=your_paystack_public_key_here

# Database (if not already in config.php)
# DB_HOST=localhost
# DB_NAME=your_database_name
# DB_USER=your_database_user
# DB_PASS=your_database_password
